generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── T1D ────────────────────────────────────────────────────────────

model GlucoseReading {
  id              String   @id @default(uuid())
  timestamp       DateTime
  value           Float
  unit            String   @default("mg/dL") // mg/dL or mmol/L
  source          String   @default("manual") // manual, nightscout, dexcom, libre
  notes           String?
  carbEntryId     String?  // FK to CarbEntry (if post-meal)
  insulinOnBoard  Float?   // calculated IOB at time of reading
  timeInRange     Boolean? // computed: within target range?
  exerciseContext String?  // pre_workout, post_workout, rest_day
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([timestamp])
}

model InsulinDose {
  id                   String   @id @default(uuid())
  timestamp            DateTime
  type                 String   // rapid, long, mixed, correction
  brand                String?  // novorapid, lantus, tresiba, etc.
  units                Float
  notes                String?
  carbEntryId          String?  // FK to CarbEntry (for bolus doses)
  insulinOnBoardAfter  Float?   // calculated IOB after this dose
  site                 String?  // injection site used
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([timestamp])
}

model BasalRate {
  id           String   @id @default(uuid())
  rate         Float    // units per hour
  startTime    String   // HH:mm format
  endTime      String   // HH:mm format
  notes        String?
  profileName  String?  // "Standard", "Workout Day", "Sick Day"
  isWorkoutDay Boolean  @default(false)
  validFrom    DateTime?
  validUntil   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Activity ──────────────────────────────────────────────────────

model Activity {
  id                String   @id @default(uuid())
  type              String   // run, swim, bike, walk, hike, other
  startTime         DateTime
  endTime           DateTime?
  distance          Float?   // meters
  elevationGain     Float?   // meters
  heartRateAvg      Int?
  heartRateMax      Int?
  calories          Int?
  notes             String?
  source            String   @default("manual") // manual, strava, apple_health
  externalId        String?  // Strava activity ID
  trainingBlockId   String?  // FK to TrainingBlock
  raceId            String?  // FK to Race
  isRace            Boolean  @default(false)
  perceivedExertion Int?     // RPE 1-10
  routeData         Json?    // GPS coordinates
  trainingLoadScore Float?   // computed: duration * intensity
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  splits            ActivitySplit[]
  trainingBlock     TrainingBlock? @relation(fields: [trainingBlockId], references: [id])
  race              Race?          @relation(fields: [raceId], references: [id])

  @@index([startTime])
  @@index([type])
}

model ActivitySplit {
  id          String   @id @default(uuid())
  activityId  String
  splitNumber Int
  distance    Float    // meters
  duration    Int      // seconds
  pace        Float?   // seconds per km
  activity    Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId])
}

model GymWorkout {
  id        String   @id @default(uuid())
  date      DateTime @default(now())
  name      String
  notes     String?
  duration  Int?     // minutes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sets      GymSet[]

  @@index([date])
}

model GymSet {
  id            String     @id @default(uuid())
  workoutId     String
  exerciseId    String
  setNumber     Int
  weight        Float?     // kg
  reps          Int?
  rpe           Float?     // 1-10
  notes         String?
  isWarmup      Boolean    @default(false)
  restSeconds   Int?       // rest after this set
  isBodyweight  Boolean    @default(false)
  bodyweightKg  Float?     // user's weight for weighted calisthenics
  workout       GymWorkout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise      Exercise   @relation(fields: [exerciseId], references: [id])

  @@index([workoutId])
  @@index([exerciseId])
}

model Exercise {
  id               String   @id @default(uuid())
  name             String
  muscleGroup      String
  equipment        String?
  instructions     String?
  gifUrl           String?
  secondaryMuscles String?
  seededAt         DateTime @default(now())
  gymSets          GymSet[]

  @@unique([name])
}

// ─── Sleep ────────────────────────────────────────────────────────

model SleepSession {
  id        String   @id @default(uuid())
  startTime DateTime
  endTime   DateTime
  quality   Int?     // 1-5
  notes     String?
  source    String   @default("manual") // manual, apple_health, oura
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  stages    SleepStage[]

  @@index([startTime])
}

model SleepStage {
  id        String   @id @default(uuid())
  sessionId String
  type      String   // deep, rem, light, awake
  startTime DateTime
  endTime   DateTime
  session   SleepSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

// ─── Body Metrics ─────────────────────────────────────────────────

model BodyMeasurement {
  id         String   @id @default(uuid())
  date       DateTime @default(now())
  weight     Float?   // kg
  bodyFatPct Float?
  waist      Float?   // cm
  chest      Float?
  bicepLeft  Float?
  bicepRight Float?
  thighLeft  Float?
  thighRight Float?
  neck       Float?
  notes      String?
  createdAt  DateTime @default(now())

  @@index([date])
}

model LabResult {
  id              String   @id @default(uuid())
  date            DateTime
  testName        String
  value           Float
  unit            String
  refRangeLow     Float?
  refRangeHigh    Float?
  labName         String?
  notes           String?
  attachmentPath  String?  // local file path
  createdAt       DateTime @default(now())

  @@index([date])
  @@index([testName])
}

model Supplement {
  id           String          @id @default(uuid())
  name         String
  brand        String?
  servingSize  Float
  servingUnit  String          @default("capsule") // capsule, tablet, ml, scoop, drop
  nutrients    String?         // JSON: [{name, amount, unit}]
  notes        String?
  createdAt    DateTime        @default(now())
  logs         SupplementLog[]

  @@unique([name, brand])
}

model SupplementLog {
  id           String     @id @default(uuid())
  date         DateTime   @default(now())
  supplementId String
  dosage       Float      // number of servings
  dosageUnit   String     @default("serving")
  timeOfDay    String?    // morning, afternoon, evening, night
  notes        String?
  supplement   Supplement @relation(fields: [supplementId], references: [id])

  @@index([date])
  @@index([supplementId])
}

// ─── Nutrition ────────────────────────────────────────────────────

model FoodItem {
  id                 String            @id @default(uuid())
  name               String
  brand              String?
  barcode            String?
  servingSize        Float?
  servingUnit        String?           // g, ml, oz, cup, piece
  calories           Float?            // per serving
  protein            Float?            // g
  carbs              Float?            // g
  fat                Float?            // g
  fiber              Float?            // g
  sugars             Float?            // g
  saturatedFat       Float?
  transFat           Float?
  cholesterol        Float?            // mg
  sodium             Float?            // mg
  potassium          Float?            // mg
  calcium            Float?            // mg
  iron               Float?            // mg
  vitaminA           Float?            // IU
  vitaminC           Float?            // mg
  vitaminD           Float?            // IU
  isSeeded           Boolean           @default(false)
  netCarbs           Float?            // computed: carbs - fiber
  isMalaysian        Boolean           @default(false)
  isCommonFood       Boolean           @default(false) // frequently eaten by this user
  createdAt          DateTime          @default(now())
  diaryEntries       FoodDiaryEntry[]

  @@index([name])
  @@index([barcode])
}

model FoodDiaryEntry {
  id              String   @id @default(uuid())
  date            DateTime @default(now())
  mealType        String   @default("snack") // breakfast, lunch, dinner, snack
  foodId          String
  servings        Float    @default(1)
  grams           Float?   // override: actual grams consumed
  carbEstimate    Float?   // user-estimated or auto-calculated carbs
  bolusSuggested  Float?   // units suggested by bolus calculator
  bolusTaken      Float?   // units actually taken
  postMealGlucose Float?   // glucose reading 2h after meal (linked)
  netCarbs        Float?   // computed from food
  costEstimate    Int?     // approximate cost in cents
  createdAt       DateTime @default(now())
  food            FoodItem @relation(fields: [foodId], references: [id])

  @@index([date])
  @@index([foodId])
}

model NutritionGoal {
  id       String @id @default(uuid())
  calories Float?
  protein  Float?  // g
  carbs    Float?  // g
  fat      Float?  // g
  fiber    Float?  // g
  waterMl  Float?
  updatedAt DateTime @updatedAt
}

model WaterLog {
  id       String   @id @default(uuid())
  date     DateTime @default(now())
  amountMl Int
  createdAt DateTime @default(now())

  @@index([date])
}

model MealPhoto {
  id        String   @id @default(uuid())
  date      DateTime @default(now())
  imagePath String
  notes     String?
  createdAt DateTime @default(now())

  @@index([date])
}

// ─── Finance ──────────────────────────────────────────────────────

model Account {
  id                   String                 @id @default(uuid())
  name                 String
  currency             String                 @default("USD")
  type                 String                 // checking, savings, cash, credit, investment, crypto, loan, mortgage
  initialBalance       Int                    @default(0) // in minor units (cents)
  isDebt               Boolean                @default(false)
  interestRate         Float?                 // annual percentage, e.g. 5.5 for 5.5%
  minimumPayment       Int?                   // minimum monthly payment in cents
  creditLimit          Int?                   // for credit cards, in cents
  paymentDueDay        Int?                   // day of month payment is due (1-31)
  payoffTarget         DateTime?              // target date to pay off the debt
  notes                String?
  isFatherSupport      Boolean                @default(false)
  isActive             Boolean                @default(true)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  transactions         Transaction[]           @relation("TransactionAccount")
  recurringTransactions RecurringTransaction[]
  financialGoals       FinancialGoal[]
}

model Asset {
  id            String   @id @default(uuid())
  name          String
  type          String   // property, vehicle, investment, crypto, gold, collectible, other
  purchaseValue Int      // original cost in cents
  currentValue  Int      // current estimated value in cents
  currency      String   @default("USD")
  purchaseDate  DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([type])
}

model RecurringTransaction {
  id              String    @id @default(uuid())
  type            String    // income, expense
  amount          Int       // in cents
  currency        String    @default("USD")
  accountId       String
  categoryId      String?
  description     String
  frequency       String    // daily, weekly, monthly, yearly
  frequencyCount  Int       @default(1) // e.g. every 2 weeks
  startDate       DateTime
  endDate         DateTime?
  nextDate        DateTime  // next occurrence
  subscriptionId  String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  account         Account   @relation(fields: [accountId], references: [id])
  category        Category? @relation(fields: [categoryId], references: [id])
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([nextDate])
  @@index([isActive])
}

model FinancialGoal {
  id            String   @id @default(uuid())
  name          String
  targetAmount  Int      // in cents
  currentAmount Int      @default(0) // in cents
  currency      String   @default("USD")
  targetDate    DateTime?
  accountId     String?
  status        String   @default("active") // active, completed, cancelled
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  account       Account? @relation(fields: [accountId], references: [id])

  @@index([status])
}

model Category {
  id                    String                  @id @default(uuid())
  name                  String
  parentId              String?
  type                  String                  // income, expense, transfer
  color                 String?
  icon                  String?
  parent                Category?               @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children              Category[]              @relation("CategoryHierarchy")
  transactions          Transaction[]
  budgets               Budget[]
  recurringTransactions RecurringTransaction[]

  @@index([type])
}

model Transaction {
  id                String   @id @default(uuid())
  date              DateTime @default(now())
  accountId         String
  categoryId        String?
  amount            Int      // in cents
  currency          String   @default("USD")
  description       String?
  notes             String?
  type              String   // income, expense, transfer
  status            String   @default("pending") // pending, cleared, reconciled
  isTransfer        Boolean  @default(false)
  transferAccountId String?
  parentTransactionId String? // for split transactions
  invoiceId         String?
  contactId         String?
  isFatherSupport   Boolean  @default(false)
  idempotencyKey    String?  // client-generated UUID for safe retries
  account           Account  @relation("TransactionAccount", fields: [accountId], references: [id])
  category          Category? @relation(fields: [categoryId], references: [id])
  parentTransaction Transaction? @relation("SplitChildren", fields: [parentTransactionId], references: [id])
  childTransactions Transaction[] @relation("SplitChildren")
  invoice           Invoice?  @relation(fields: [invoiceId], references: [id])
  contact           Contact?  @relation(fields: [contactId], references: [id])
  audits            TransactionAudit[]

  @@index([date])
  @@index([accountId])
  @@index([categoryId])
  @@index([status])
  @@index([parentTransactionId])
  @@unique([idempotencyKey])
}

model TransactionAudit {
  id            String   @id @default(uuid())
  transactionId String
  action        String   // created, updated, deleted
  changes       Json     // { before: {...}, after: {...} } or { deleted: {...} }
  timestamp     DateTime @default(now())
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([timestamp])
}

model Budget {
  id         String   @id @default(uuid())
  categoryId String
  month      DateTime // first day of month
  amount     Int      // in cents
  currency   String   @default("USD")
  category   Category @relation(fields: [categoryId], references: [id])

  @@unique([categoryId, month])
}

model ExchangeRate {
  id           String   @id @default(uuid())
  fromCurrency String
  toCurrency   String
  rate         Float
  date         DateTime @default(now())

  @@unique([fromCurrency, toCurrency, date])
  @@index([fromCurrency, toCurrency])
}

// ─── Productivity ─────────────────────────────────────────────────

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime?
  priority    String   @default("medium") // low, medium, high, urgent
  status      String   @default("todo") // todo, in_progress, done, cancelled
  projectId   String?
  tags        String?  // comma-separated
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project? @relation(fields: [projectId], references: [id])

  @@index([status])
  @@index([dueDate])
  @@index([projectId])
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  status      String   @default("active") // active, completed, archived
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       Task[]
}

model Habit {
  id             String   @id @default(uuid())
  name           String
  frequency      String   @default("daily") // daily, weekly, monthly
  frequencyCount Int      @default(1) // how many times per period
  timeOfDay      String?  // morning, afternoon, evening, anytime
  category       String?
  color          String?
  createdAt      DateTime @default(now())
  logs           HabitLog[]

  @@index([frequency])
}

model HabitLog {
  id        String   @id @default(uuid())
  habitId   String
  date      DateTime @default(now())
  completed Boolean  @default(true)
  notes     String?
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([habitId])
  @@index([date])
}

model JournalEntry {
  id        String   @id @default(uuid())
  date      DateTime @default(now())
  content   String   // markdown
  mood      String?  // great, good, okay, bad, terrible
  tags      String?  // comma-separated
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date])
}

model CalendarEvent {
  id          String   @id @default(uuid())
  externalId  String?  // CalDAV UID
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  location    String?
  source      String   @default("manual") // manual, caldav
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([startTime])
  @@index([externalId])
}

// ─── System ───────────────────────────────────────────────────

model Insight {
  id         String   @id @default(uuid())
  type       String   // glucose, sleep, habit, finance, task, activity, prayer, custom
  urgency    String   // high, medium, low
  headline   String
  body       String
  href       String?  // link to relevant module page
  icon       String?
  sourceData Json?    // snapshot of the data that generated this insight
  dismissed  Boolean  @default(false)
  actedOn    Boolean  @default(false)
  expiresAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([type])
  @@index([urgency])
  @@index([dismissed])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  body      String
  href      String?  // deep-link to relevant module page
  read      Boolean  @default(false)
  pushed    Boolean  @default(false) // sent to browser via push/service worker
  createdAt DateTime @default(now())

  @@index([read])
  @@index([pushed])
  @@index([createdAt])
}

// ─── Finance (Phase 1) ─────────────────────────────────────────────

model Invoice {
  id            String   @id @default(uuid())
  invoiceNumber String   @unique
  clientId      String
  projectId     String?
  status        String   @default("draft") // draft, sent, paid, overdue, cancelled
  currency      String   @default("MYR")
  subtotal      Int
  taxRate       Float    @default(0)
  taxAmount     Int      @default(0)
  total         Int
  issuedDate    DateTime @default(now())
  dueDate       DateTime
  paidDate      DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lineItems     InvoiceLineItem[]
  payments      PaymentReceived[]
  transactions  Transaction[]
  client        Contact    @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([status])
  @@index([dueDate])
}

model InvoiceLineItem {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  quantity    Float   @default(1)
  unitPrice   Int
  amount      Int
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model PaymentReceived {
  id            String   @id @default(uuid())
  invoiceId     String
  amount        Int
  currency      String   @default("MYR")
  paymentDate   DateTime @default(now())
  method        String?  // bank_transfer, wise, paypal, cash
  reference     String?
  notes         String?
  transactionId String?
  invoice       Invoice  @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
}

model RunwaySnapshot {
  id              String   @id @default(uuid())
  date            DateTime @default(now())
  totalSavings    Int
  monthlyBurnRate Int
  runwayMonths    Float
  monthlyIncome   Int
  notes           String?

  @@index([date])
}

model Subscription {
  id              String   @id @default(uuid())
  name            String
  provider        String
  amount          Int
  currency        String   @default("MYR")
  billingCycle    String   // monthly, yearly, weekly
  nextBillingDate DateTime
  category        String?  // software, rent, phone, health, education
  isActive        Boolean  @default(true)
  notes           String?
  recurringTxId   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  recurringTransactions RecurringTransaction[]

  @@index([nextBillingDate])
  @@index([isActive])
}

// ─── T1D (Phase 1) ───────────────────────────────────────────────

model CarbEntry {
  id              String   @id @default(uuid())
  timestamp       DateTime
  carbs           Float    // grams of carbohydrates
  description     String?  // "nasi lemak", "pre-run banana"
  source          String   @default("manual") // manual, food_diary
  foodDiaryEntryId String? // link to nutrition module
  createdAt       DateTime @default(now())

  @@index([timestamp])
}

model InsulinCarbRatio {
  id         String   @id @default(uuid())
  ratio      Float    // grams of carbs per 1 unit of insulin
  timeOfDay  String   // morning, afternoon, evening, night
  validFrom  DateTime @default(now())
  validUntil DateTime?
  notes      String?

  @@index([validFrom])
}

model CorrectionFactor {
  id         String   @id @default(uuid())
  factor     Float    // mg/dL drop per 1 unit of insulin
  timeOfDay  String   // morning, afternoon, evening, night
  validFrom  DateTime @default(now())
  validUntil DateTime?
  notes      String?

  @@index([validFrom])
}

model TargetRange {
  id         String   @id @default(uuid())
  low        Float    // mg/dL
  high       Float    // mg/dL
  timeOfDay  String   // morning, afternoon, evening, night, workout
  validFrom  DateTime @default(now())
  validUntil DateTime?

  @@index([validFrom])
}

model KetoneReading {
  id        String   @id @default(uuid())
  timestamp DateTime
  value     Float    // mmol/L
  type      String   @default("blood") // blood, urine
  context   String?  // "post long run", "illness", "routine check"
  notes     String?
  createdAt DateTime @default(now())

  @@index([timestamp])
}

model InjectionSite {
  id          String   @id @default(uuid())
  site        String   // abdomen_l, abdomen_r, thigh_l, thigh_r, arm_l, arm_r, buttock_l, buttock_r
  usedAt      DateTime
  insulinType String   // rapid, long
  notes       String?

  @@index([usedAt])
  @@index([site])
}

// ─── Nutrition (Phase 1) ──────────────────────────────────────────

model Recipe {
  id           String   @id @default(uuid())
  name         String
  description  String?
  servings     Float    @default(1)
  prepTime     Int?     // minutes
  cookTime     Int?     // minutes
  instructions String?  // markdown
  notes        String?
  isMalaysian  Boolean  @default(false)
  totalCalories Float?  // computed from ingredients
  totalCarbs   Float?
  totalProtein Float?
  totalFat     Float?
  totalFiber   Float?
  netCarbs     Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  ingredients  RecipeIngredient[]

  @@index([name])
}

model RecipeIngredient {
  id        String  @id @default(uuid())
  recipeId  String
  foodId    String? // optional — can use custom name
  name      String  // "chicken breast" if no foodId
  amount    Float
  unit      String  // g, ml, cup, tbsp, piece
  recipe    Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

model FrequentFood {
  id              String   @id @default(uuid())
  foodId          String
  personalName    String?  // "Mom's nasi lemak"
  typicalCarbs    Float?   // user's estimate for typical serving
  typicalServing  Float?   // grams
  typicalGlucose  Float?   // avg post-meal glucose (computed)
  useCount        Int      @default(0)
  lastUsedAt      DateTime?
  notes           String?

  @@unique([foodId])
}

model FoodCost {
  id           String   @id @default(uuid())
  foodId       String?
  foodName     String   // "Chicken breast"
  store        String?  // "NSK", "Mydin"
  price        Int      // cents (MYR)
  quantity     Float
  unit         String   // kg, pack, piece
  pricePerUnit Float?   // computed: price / quantity
  date         DateTime @default(now())
  notes        String?

  @@index([foodId])
  @@index([date])
}

model FastingSession {
  id              String   @id @default(uuid())
  date            DateTime
  type            String   @default("ramadan") // ramadan, intermittent, voluntary_sunnah
  startTime       DateTime // suhoor end / fajr
  endTime         DateTime // iftar / maghrib
  duration        Float?   // computed: hours fasted
  preFastMealId   String?  // FK to FoodDiaryEntry (suhoor)
  postFastMealId  String?  // FK to FoodDiaryEntry (iftar)
  preFastGlucose  Float?
  postFastGlucose Float?
  notes           String?
  createdAt       DateTime @default(now())

  @@index([date])
  @@index([type])
}

// ─── CRM ───────────────────────────────────────────────────────

model Contact {
  id                 String   @id @default(uuid())
  firstName          String
  lastName           String?
  fullName           String
  type               String   // family, partner, friend, client, mentor, colleague, acquaintance
  subType            String?  // girlfriend, father, client_leads, client_active, university_lecturer
  groupId            String?
  birthday           DateTime?
  birthYear          Int?
  nationality        String?
  location           String?
  languages          String?
  email              String?
  phone              String?
  whatsapp           String?
  telegram           String?
  socialLinks        Json?
  bio                String?
  preferences        String?
  importantDates     Json?
  relationshipHealth String?  // strong, good, needs_attention, strained, dormant
  lastContactedAt    DateTime?
  nextFollowUpAt     DateTime?
  followUpFrequency  String?  // daily, weekly, biweekly, monthly, quarterly
  isKeyPerson        Boolean  @default(false)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  interactions       Interaction[]
  invoices           Invoice[]
  transactions       Transaction[]
  group              ContactGroup? @relation(fields: [groupId], references: [id])

  @@index([type])
  @@index([relationshipHealth])
  @@index([nextFollowUpAt])
  @@index([isKeyPerson])
}

model Interaction {
  id          String   @id @default(uuid())
  contactId   String
  date        DateTime @default(now())
  type        String   // call, message, meeting, email, video_call, in_person
  direction   String   // outgoing, incoming
  platform    String?  // whatsapp, telegram, phone, zoom, in_person
  summary     String
  actionItems String?
  mood        String?  // positive, neutral, negative
  duration    Int?     // minutes
  tags        String?
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([date])
}

model ContactGroup {
  id        String    @id @default(uuid())
  name      String    @unique
  color     String?
  icon      String?
  sortOrder Int       @default(0)
  contacts  Contact[]
}

