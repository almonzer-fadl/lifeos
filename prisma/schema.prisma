// ─── Prayer / Quran (Phase 1) ──────────────────────────────────────

model PrayerLog {
  id          String   @id @default(uuid())
  date        DateTime
  prayer      String   // fajr, dhuhr, asr, maghrib, isha
  status      String   @default("on_time") // on_time, late, qadha, missed
  prayedAt    DateTime?
  scheduledAt DateTime
  notes       String?
  createdAt   DateTime @default(now())

  @@unique([date, prayer])
  @@index([date])
}

model QuranProgress {
  id              String   @id @default(uuid())
  totalPages      Int      @default(604)
  pagesMemorized  Int      @default(0)
  currentSurah    String?
  currentJuz      Int?
  currentPage     Int?
  targetDate      DateTime?
  method          String?
  teacher         String?
  startedAt       DateTime
  notes           String?
  updatedAt       DateTime @updatedAt
  sessions        QuranSession[]
}

model QuranSession {
  id              String        @id @default(uuid())
  quranProgressId String?
  date            DateTime      @default(now())
  type            String        // new_memorization, revision, recitation_to_teacher, tafsir
  startPage       Int?
  endPage         Int?
  pagesMemorized  Float?
  pagesRevised    Float?
  duration        Int?          // minutes
  quality         Int?          // 1-5
